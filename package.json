{
  "name": "kratos-terminal",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "check:env": "node scripts/check-env.mjs",
    "smoke:test": "node scripts/smoke-test.mjs",
